{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["job_title", "company", "seniority", "applicant_profile", "job_summary", "responsibilities", "required_skills", "preferred_skills", "ats_keywords", "application_questions", "contacts", "evidence_map", "gaps", "screening_warnings", "verification_needed", "experience_assessment", "project_assessment", "source_item_counts", "generation_constraints"],
  "properties": {
    "job_title": {"type": "string"},
    "company": {"type": "string"},
    "seniority": {"type": "string"},
    "applicant_profile": {"type": "object"},
    "job_summary": {"type": "string"},
    "responsibilities": {"type": "array", "maxItems": 10, "items": {"type": "string"}},
    "required_skills": {"type": "array", "items": {"type": "string"}},
    "preferred_skills": {"type": "array", "items": {"type": "string"}},
    "ats_keywords": {"type": "array", "maxItems": 15, "items": {"type": "string"}},
    "application_questions": {"type": "array", "items": {"type": "string"}},
    "contacts": {"type": "array", "items": {"type": "object"}},
    "evidence_map": {"type": "array", "items": {"type": "object"}},
    "gaps": {"type": "array", "items": {"type": "string"}},
    "screening_warnings": {"type": "array", "items": {"type": "string"}},
    "verification_needed": {"type": "array", "items": {"type": "string"}},
    "experience_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement", "confirmed_months", "confirmed_or_possible_months", "status", "caution", "roles"],
      "properties": {
        "requirement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "minimum_months", "wording"],
          "properties": {
            "kind": {"enum": ["mandatory", "preferred", "ambiguous", "none"]},
            "minimum_months": {"type": "integer", "minimum": 0},
            "wording": {"type": "string"}
          }
        },
        "confirmed_months": {"type": "integer", "minimum": 0},
        "confirmed_or_possible_months": {"type": "integer", "minimum": 0},
        "status": {"enum": ["not_applicable", "sufficient", "sufficient_with_caution", "insufficient"]},
        "caution": {"type": "string"},
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "experience_type", "relevance", "count_status", "evidence", "rationale", "start_month", "end_month", "elapsed_months"],
            "properties": {
              "role": {"type": "string"},
              "experience_type": {"enum": ["professional_employment", "formal_internship", "academic_employment", "volunteering", "student_team", "other"]},
              "relevance": {"enum": ["direct", "supporting", "unrelated"]},
              "count_status": {"enum": ["confirmed", "possible", "excluded"]},
              "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
              "rationale": {"type": "string"},
              "start_month": {"type": "string"},
              "end_month": {"type": ["string", "null"]},
              "elapsed_months": {"type": "integer", "minimum": 0}
            }
          }
        }
      }
    },
    "project_assessment": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project", "relevance", "evidence", "rationale"],
        "properties": {
          "project": {"type": "string"},
          "relevance": {"enum": ["direct", "supporting", "unrelated"]},
          "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "rationale": {"type": "string"}
        }
      }
    },
    "source_item_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experience", "projects"],
      "properties": {
        "experience": {"type": "integer", "minimum": 0},
        "projects": {"type": "integer", "minimum": 0}
      }
    },
    "generation_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cv_word_budget", "letter_word_budget", "required_cv_sections", "supported_concepts", "natural_writing"],
      "properties": {
        "cv_word_budget": {"type": "array", "prefixItems": [{"type": "integer"}, {"type": "integer"}], "items": false},
        "letter_word_budget": {"type": "array", "prefixItems": [{"type": "integer"}, {"type": "integer"}], "items": false},
        "required_cv_sections": {"type": "array", "items": {"type": "string"}},
        "supported_concepts": {"type": "array", "items": {"type": "string"}},
        "natural_writing": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
