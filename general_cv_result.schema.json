{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "attempts", "message"],
  "properties": {
    "status": {"type": "string", "enum": ["PASS", "NEEDS REVIEW"]},
    "attempts": {"type": "integer", "minimum": 1},
    "message": {"type": "string"}
  }
}
